{
  "platform_specific": {
    "packages": [
      "calamares",
      "calamares-config-archiso",
      "kconfig",
      "kcoreaddons",
      "icoutils",
      "kservice",
      "solid",
      "yaml-cpp",
      "parted",
      "gptfdisk",
      "dosfstools",
      "e2fsprogs",
      "btrfs-progs",
      "xfsprogs",
      "f2fs-tools",
      "squashfs-tools",
      "rsync"
    ]
  },
  "package_sources": {
    "aur": []
  },
  "customizations": {
    "services": []
  },
  "desktop_environment": {
    "customizations_path": "configs/custom_files/",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "calamares",
        "destination": "/etc/calamares"
      }
    ]
  }
}
