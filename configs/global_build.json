{
  "metadata": {
    "name": "Arch-Builder Master Config",
    "version": "1.0.0",
    "description": "Global manifest for building modular ISOs."
  },
  "defaults": {
    "desktop": "xfce",
    "kernel": "linux",
    "package_profiles": [
      "base",
      "custom-user",
      "xorg"
    ],
    "service_profiles": [
      "common-base"
    ]
  },
  "customizations": {
    "timezone": "UTC",
    "locale": "en_US.UTF-8",
    "keymap": "us"
  },
  "build_environment": {
    "workdir_base": "arch-builder/workdir",
    "iso_label": "ARCH-MODERN",
    "binaries": {
      "grub_mkrescue": "/usr/bin/grub-mkrescue",
      "genisoimage": "/usr/bin/genisoimage"
    }
  },
  "system": {
    "workdir_base": "arch-builder/workdir",
    "iso_label": "ARCH-MODERN",
    "binaries": {
      "grub-mkrescue": "/usr/bin/grub-mkrescue",
      "grub_mkrescue": "/usr/bin/grub-mkrescue",
      "genisomake": "/usr/bin/genisoimage",
      "genisoimage": "/usr/bin/genisoimage"
    }
  },
  "boot": {
    "kernel_params": "loglevel=3 quiet splash rd.udev.log_level=3 vt.global_cursor_default=0 nouveau.modeset=1 radeon.modeset=1 i915.modeset=1 nvme_load=yes"
  },
  "components": {
    "bootloaders": [
      {
        "name": "grub",
        "type": "module"
      },
      {
        "name": "syslinux",
        "type": "module"
      }
    ],
    "kernels": [
      {
        "name": "linux",
        "type": "module"
      },
      {
        "name": "linux-lts",
        "type": "module"
      },
      {
        "name": "linux-zen",
        "type": "module"
      },
      {
        "name": "linux-hardened",
        "type": "module"
      }
    ]
  }
}