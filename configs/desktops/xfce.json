{
  "platform_specific": {
    "packages": [
      "xfce4",
      "xfce4-goodies",
      "xfce4-power-manager",
      "xfce4-session",
      "xfdesktop",
      "thunar",
      "thunar-volman",
      "lightdm",
      "lightdm-gtk-greeter",
      "firefox",
      "network-manager-applet",
      "xclip",
      "xsel",
      "spice-vdagent"
    ]
  },
  "package_sources": {
    "aur": []
  },
  "customizations": {
    "services": [
      "lightdm"
    ],
    "users": [
      {
        "name": "live",
        "groups": [
          "wheel",
          "video",
          "audio",
          "networkmanager",
          "autologin"
        ],
        "password": "live"
      }
    ]
  },
  "desktop_environment": {
    "customizations_path": "configs/custom_files/",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "desktops/xfce/etc/lightdm",
        "destination": "/etc/lightdm"
      },
      {
        "source": "desktops/xfce/etc/skel",
        "destination": "/etc/skel"
      },
      {
        "source": "desktops/xfce/etc/xdg",
        "destination": "/etc/xdg"
      }
    ]
  }
}
