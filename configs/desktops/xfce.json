{
  "platform_specific": {
    "packages": [
      "xfce4",
      "xfce4-goodies",
      "xfce4-power-manager",
      "xfce4-session",
      "xfdesktop",
      "thunar",
      "thunar-volman",
      "lightdm",
      "lightdm-gtk-greeter",
      "firefox",
      "network-manager-applet",
      "networkmanager",
      "pipewire",
      "pipewire-pulse",
      "pipewire-alsa",
      "alsa-utils",
      "bluez",
      "blueman",
      "cups",
      "system-config-printer",
      "gvfs",
      "gvfs-smb",
      "gvfs-mtp",
      "ntfs-3g",
      "exfat-utils",
      "sudo",
      "vim",
      "terminus-font",
      "base-devel",
      "xclip",
      "xsel",
      "spice-vdagent"
    ]
  },
  "customizations": {
    "services": [
      "lightdm"
    ],
    "users": [
      {
        "name": "live",
        "groups": [
          "wheel",
          "video",
          "audio",
          "networkmanager",
          "autologin"
        ],
        "password": "live"
      }
    ]
  },
  "system_config": {
    "files": [
      {
        "src": "configs/custom_files/etc/lightdm/lightdm.conf",
        "dest": "/etc/lightdm/lightdm.conf",
        "mode": "0644"
      },
      {
        "src": "configs/custom_files/etc/lightdm/lightdm-gtk-greeter.conf",
        "dest": "/etc/lightdm/lightdm-gtk-greeter.conf",
        "mode": "0644"
      }
    ]
  }
}