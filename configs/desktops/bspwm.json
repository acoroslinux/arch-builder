{
  "platform_specific": {
    "packages": [
      "bspwm",
      "sxhkd",
      "xorg-server",
      "lightdm",
      "lightdm-gtk-greeter",
      "alacritty",
      "thunar",
      "firefox",
      "dmenu",
      "polybar",
      "networkmanager",
      "network-manager-applet",
      "pipewire",
      "pipewire-pulse",
      "pipewire-alsa",
      "wireplumber",
      "alsa-utils",
      "bluez",
      "bluez-utils",
      "blueman",
      "xclip",
      "xsel",
      "spice-vdagent"
    ]
  },
  "package_sources": {
    "aur": []
  },
  "customizations": {
    "services": [
      "lightdm",
      "NetworkManager"
    ],
    "users": [
      {
        "name": "live",
        "groups": [
          "wheel",
          "video",
          "audio",
          "networkmanager",
          "autologin"
        ],
        "password": "live"
      }
    ]
  },
  "system_config": {
    "files": [
      {
        "src": "configs/custom_files/desktops/xfce/etc/lightdm/lightdm.conf",
        "dest": "/etc/lightdm/lightdm.conf",
        "mode": "0644"
      },
      {
        "src": "configs/custom_files/desktops/xfce/etc/lightdm/lightdm-gtk-greeter.conf",
        "dest": "/etc/lightdm/lightdm-gtk-greeter.conf",
        "mode": "0644"
      },
      {
        "src": "configs/custom_files/desktops/bspwm/etc/skel/.bashrc",
        "dest": "/etc/skel/.bashrc",
        "mode": "0644"
      }
    ],
    "commands": [
      "sed -i 's/user-session=xfce/user-session=bspwm/' /etc/lightdm/lightdm.conf"
    ]
  }
}
