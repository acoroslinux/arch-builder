{
  "platform_specific": {
    "packages": [
      "gnome",
      "gnome-tweaks",
      "gdm",
      "xorg-server",
      "gnome-terminal",
      "firefox",
      "xclip",
      "xsel",
      "spice-vdagent"
    ]
  },
  "package_sources": {
    "aur": []
  },
  "customizations": {
    "services": [
      "gdm",
      "NetworkManager"
    ],
    "users": [
      {
        "name": "live",
        "groups": [
          "wheel",
          "video",
          "audio",
          "networkmanager",
          "autologin"
        ],
        "password": "live"
      }
    ]
  },
  "desktop_environment": {
    "customizations_path": "configs/custom_files/",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "desktops/gnome/etc/skel",
        "destination": "/etc/skel"
      },
      {
        "source": "desktops/gnome/etc/gdm",
        "destination": "/etc/gdm"
      }
    ]
  }
}
