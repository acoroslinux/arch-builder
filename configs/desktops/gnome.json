{
  "platform_specific": {
    "packages": [
      "gnome",
      "gnome-tweaks",
      "gdm",
      "xorg-server",
      "gnome-terminal",
      "firefox",
      "xclip",
      "xsel",
      "spice-vdagent"
    ]
  },
  "package_sources": {
    "aur": []
  },
  "customizations": {
    "services": [
      "gdm",
      "NetworkManager"
    ],
    "users": [
      {
        "name": "live",
        "groups": [
          "wheel",
          "video",
          "audio",
          "networkmanager",
          "autologin"
        ],
        "password": "live"
      }
    ]
  },
  "system_config": {
    "files": [
      {
        "src": "configs/custom_files/desktops/gnome/etc/gdm/custom.conf",
        "dest": "/etc/gdm/custom.conf",
        "mode": "0644"
      },
      {
        "src": "configs/custom_files/desktops/gnome/etc/skel/.bashrc",
        "dest": "/etc/skel/.bashrc",
        "mode": "0644"
      }
    ]
  }
}
