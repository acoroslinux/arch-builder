{
  "platform_specific": {
    "packages": [
      "lxqt",
      "breeze-icons",
      "oxygen-icons",
      "sddm",
      "firefox",
      "xclip",
      "xsel",
      "spice-vdagent"
    ]
  },
  "package_sources": {
    "aur": []
  },
  "customizations": {
    "services": [
      "sddm",
      "NetworkManager"
    ],
    "users": [
      {
        "name": "live",
        "groups": [
          "wheel",
          "video",
          "audio",
          "networkmanager",
          "autologin"
        ],
        "password": "live"
      }
    ]
  },
  "system_config": {
    "files": [
      {
        "src": "configs/custom_files/desktops/kde/etc/sddm.conf.d/autologin.conf",
        "dest": "/etc/sddm.conf.d/autologin.conf",
        "mode": "0644"
      },
      {
        "src": "configs/custom_files/desktops/lxqt/etc/skel/.bashrc",
        "dest": "/etc/skel/.bashrc",
        "mode": "0644"
      }
    ]
  }
}
