{
  "platform_specific": {
    "packages": [
      "lxqt",
      "breeze-icons",
      "oxygen-icons",
      "sddm",
      "firefox",
      "xclip",
      "xsel",
      "spice-vdagent"
    ]
  },
  "package_sources": {
    "aur": []
  },
  "customizations": {
    "services": [
      "sddm",
      "NetworkManager"
    ],
    "users": [
      {
        "name": "live",
        "groups": [
          "wheel",
          "video",
          "audio",
          "networkmanager",
          "autologin"
        ],
        "password": "live"
      }
    ]
  },
  "desktop_environment": {
    "customizations_path": "configs/custom_files/",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "desktops/lxqt/etc/skel",
        "destination": "/etc/skel"
      }
    ]
  }
}
