{
  "platform_specific": {
    "packages": [
      "plasma-meta",
      "konsole",
      "dolphin",
      "kate",
      "ark",
      "sddm",
      "wayland",
      "firefox",
      "networkmanager",
      "pipewire",
      "pipewire-pulse",
      "pipewire-alsa",
      "wireplumber",
      "alsa-utils",
      "bluez",
      "bluez-utils",
      "xclip",
      "xsel",
      "spice-vdagent"
    ]
  },
  "customizations": {
    "services": [
      "sddm",
      "NetworkManager"
    ],
    "users": [
      {
        "name": "live",
        "groups": [
          "wheel",
          "video",
          "audio",
          "networkmanager",
          "autologin"
        ],
        "password": "live"
      }
    ]
  },
  "system_config": {
    "files": [
      {
        "src": "configs/custom_files/etc/sddm.conf.d/autologin.conf",
        "dest": "/etc/sddm.conf.d/autologin.conf",
        "mode": "0644"
      }
    ]
  }
}