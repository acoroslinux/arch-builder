{
  "platform_specific": {
    "packages": [
      "awesome",
      "xorg-server",
      "lightdm",
      "lightdm-gtk-greeter",
      "alacritty",
      "thunar",
      "firefox",
      "dmenu",
      "network-manager-applet",
      "xclip",
      "xsel",
      "spice-vdagent"
    ]
  },
  "package_sources": {
    "aur": []
  },
  "customizations": {
    "services": [
      "lightdm",
      "NetworkManager"
    ],
    "users": [
      {
        "name": "live",
        "groups": [
          "wheel",
          "video",
          "audio",
          "networkmanager",
          "autologin"
        ],
        "password": "live"
      }
    ]
  },
  "system_config": {
    "commands": [
      "sed -i 's/user-session=xfce/user-session=awesome/' /etc/lightdm/lightdm.conf"
    ]
  },
  "desktop_environment": {
    "customizations_path": "configs/custom_files/",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "desktops/awesome/etc/skel",
        "destination": "/etc/skel"
      }
    ]
  }
}
