{
  "platform_specific": {
    "packages": [
      "hyprland",
      "waybar",
      "wofi",
      "alacritty",
      "thunar",
      "firefox",
      "network-manager-applet",
      "wl-clipboard",
      "xclip",
      "xsel",
      "spice-vdagent"
    ]
  },
  "package_sources": {
    "aur": []
  },
  "customizations": {
    "services": [
      "NetworkManager"
    ],
    "users": [
      {
        "name": "live",
        "groups": [
          "wheel",
          "video",
          "audio",
          "networkmanager",
          "autologin"
        ],
        "password": "live"
      }
    ]
  },
  "system_config": {
    "files": [
      {
        "src": "configs/custom_files/desktops/hyprland/etc/systemd/system/getty@tty1.service.d/autologin.conf",
        "dest": "/etc/systemd/system/getty@tty1.service.d/autologin.conf",
        "mode": "0644"
      },
      {
        "src": "configs/custom_files/desktops/hyprland/etc/skel/.bash_profile",
        "dest": "/etc/skel/.bash_profile",
        "mode": "0644"
      }
    ]
  }
}
