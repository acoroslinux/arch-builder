{
  "platform_specific": {
    "packages": [
      "hyprland",
      "waybar",
      "wofi",
      "alacritty",
      "thunar",
      "firefox",
      "network-manager-applet",
      "wl-clipboard",
      "xclip",
      "xsel",
      "spice-vdagent"
    ]
  },
  "package_sources": {
    "aur": []
  },
  "customizations": {
    "services": [
      "NetworkManager"
    ],
    "users": [
      {
        "name": "live",
        "groups": [
          "wheel",
          "video",
          "audio",
          "networkmanager",
          "autologin"
        ],
        "password": "live"
      }
    ]
  },
  "desktop_environment": {
    "customizations_path": "configs/custom_files/",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "desktops/hyprland/etc/skel",
        "destination": "/etc/skel"
      },
      {
        "source": "desktops/hyprland/etc/systemd",
        "destination": "/etc/systemd"
      }
    ]
  }
}
