{
  "platform_specific": {
    "packages": [
      "pantheon",
      "xorg-server",
      "lightdm",
      "lightdm-pantheon-greeter",
      "pantheon-terminal",
      "pantheon-files",
      "firefox",
      "network-manager-applet",
      "xclip",
      "xsel",
      "spice-vdagent"
    ]
  },
  "package_sources": {
    "aur": []
  },
  "customizations": {
    "services": [
      "lightdm",
      "NetworkManager"
    ],
    "users": [
      {
        "name": "live",
        "groups": [
          "wheel",
          "video",
          "audio",
          "networkmanager",
          "autologin"
        ],
        "password": "live"
      }
    ]
  },
  "system_config": {
    "files": [
      {
        "src": "configs/custom_files/desktops/xfce/etc/lightdm/lightdm.conf",
        "dest": "/etc/lightdm/lightdm.conf",
        "mode": "0644"
      },
      {
        "src": "configs/custom_files/desktops/pantheon/etc/skel/.bashrc",
        "dest": "/etc/skel/.bashrc",
        "mode": "0644"
      }
    ],
    "commands": [
      "sed -i 's/user-session=xfce/user-session=pantheon/' /etc/lightdm/lightdm.conf"
    ]
  }
}
