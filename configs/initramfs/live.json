{
    "name": "live-initramfs",
    "description": "Initramfs configuration for live ISO boot with archiso hooks.",
    "initramfs_config": {
        "modules": [
            "loop",
            "overlay"
        ],
        "binaries": [
            "fsck",
            "fsck.fat"
        ],
        "hooks": [
            "base",
            "udev",
            "modconf",
            "archiso",
            "block",
            "filesystems",
            "keyboard"
        ]
    }
}

