{
  "platform_specific": {
    "architecture": "x86_64",
    "base_kernel": "vmlinuz-linux",
    "initramfs": "initramfs-linux.img",
    "initramfs_config": {
      "modules": [
        "squashfs",
        "overlay",
        "loop"
      ],
      "binaries": [],
      "files": [],
      "hooks": [
        "base",
        "udev",
        "kms",
        "plymouth",
        "modconf",
        "memdisk",
        "archiso",
        "archiso_loop_mnt",
        "block",
        "filesystems",
        "keyboard"
      ]
    },
    "packages": [
      {
        "name": "base"
      },
      {
        "name": "linux"
      },
      {
        "name": "linux-firmware"
      },
      {
        "name": "linux-firmware-marvell"
      },
      {
        "name": "linux-firmware-nfp"
      },
      {
        "name": "linux-firmware-qlogic"
      },
      {
        "name": "linux-firmware-bnx2x"
      },
      {
        "name": "linux-firmware-liquidio"
      },
      {
        "name": "linux-firmware-mellanox"
      },
      {
        "name": "sof-firmware"
      },
      {
        "name": "alsa-firmware"
      },
      {
        "name": "wireless-regdb"
      },
      {
        "name": "intel-ucode"
      },
      {
        "name": "amd-ucode"
      },
      {
        "name": "archiso"
      },
      {
        "name": "mkinitcpio-archiso"
      },
      {
        "name": "dosfstools"
      },
      {
        "name": "mtools"
      },
      {
        "name": "pv"
      },
      {
        "name": "grub"
      },
      {
        "name": "efibootmgr"
      },
      {
        "name": "xdg-user-dirs"
      },
      {
        "name": "networkmanager"
      },
      {
        "name": "sudo"
      },
      {
        "name": "nano"
      },
      {
        "name": "bash"
      },
      {
        "name": "qt6-svg"
      },
      {
        "name": "qt6-declarative"
      },
      {
        "name": "os-prober"
      }
    ],
    "mounts": [
      {
        "source": "/",
        "target": "/",
        "type": "ext4"
      }
    ]
  },
  "system_info": {
    "root_device_id": "/dev/disk/by-uuid/UUID_DO_NOT_FORGET_THIS",
    "workdir_base": "arch-builder/workdir"
  },
  "customizations": {
    "hostname": "arch-builder",
    "timezone": "UTC",
    "locale": "en_US.UTF-8",
    "keymap": "us",
    "users": [
      {
        "name": "live",
        "groups": [
          "wheel",
          "video",
          "audio",
          "networkmanager"
        ],
        "password": "live"
      }
    ],
    "services": [
      "NetworkManager",
      "systemd-timesyncd",
      "bluetooth",
      "avahi-daemon",
      "cups",
      "smb",
      "nmb"
    ]
  },
  "system_config": {
    "commands": [
      "echo 'Build finished' > /var/log/build_status.txt",
      "mkdir -p /srv/samba/public",
      "chown nobody:nobody /srv/samba/public",
      "chmod 1777 /srv/samba/public"
    ],
    "files": [
      {
        "src": "configs/custom_files/etc/vconsole.conf",
        "dest": "/etc/vconsole.conf",
        "mode": "0644"
      },
      {
        "src": "configs/custom_files/sudoers.d/99-live-user",
        "dest": "/etc/sudoers.d/99-live-user",
        "mode": "0440"
      }
    ]
  }
}