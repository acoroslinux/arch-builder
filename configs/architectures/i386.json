{
  "platform_specific": {
    "architecture": "i386",
    "base_kernel": "vmlinuz-linux",
    "initramfs": "initramfs-linux.img",
    "initramfs_config": {
      "modules": [
        "squashfs",
        "overlay",
        "loop"
      ],
      "binaries": [],
      "files": [],
      "hooks": [
        "base",
        "udev",
        "plymouth",
        "modconf",
        "kms",
        "memdisk",
        "archiso",
        "archiso_loop_mnt",
        "block",
        "filesystems",
        "keyboard"
      ]
    },
    "packages": [
      {
        "name": "base"
      },
      {
        "name": "linux"
      },
      {
        "name": "linux-firmware"
      },
      {
        "name": "linux-firmware-marvell"
      },
      {
        "name": "linux-firmware-nfp"
      },
      {
        "name": "linux-firmware-qlogic"
      },
      {
        "name": "linux-firmware-bnx2x"
      },
      {
        "name": "linux-firmware-liquidio"
      },
      {
        "name": "linux-firmware-mellanox"
      },
      {
        "name": "sof-firmware"
      },
      {
        "name": "alsa-firmware"
      },
      {
        "name": "wireless-regdb"
      },
      {
        "name": "archiso"
      },
      {
        "name": "mkinitcpio-archiso"
      },
      {
        "name": "dosfstools"
      },
      {
        "name": "mtools"
      },
      {
        "name": "pv"
      },
      {
        "name": "grub"
      },
      {
        "name": "xdg-user-dirs"
      },
      {
        "name": "networkmanager"
      },
      {
        "name": "sudo"
      },
      {
        "name": "nano"
      },
      {
        "name": "bash"
      }
    ],
    "mounts": [
      {
        "source": "/",
        "target": "/",
        "type": "ext4"
      }
    ]
  },
  "system_info": {
    "root_device_id": "/dev/disk/by-uuid/ARCH_BUILDER_ISO",
    "workdir_base": "arch-builder/workdir"
  },
  "customizations": {
    "hostname": "arch-builder-i386",
    "timezone": "UTC",
    "locale": "en_US.UTF-8",
    "keymap": "us",
    "users": [
      {
        "name": "live",
        "groups": [
          "wheel",
          "audio",
          "networkmanager"
        ],
        "password": "live"
      }
    ],
    "services": [
      "NetworkManager"
    ]
  },
  "system_config": {
    "overlay_dir": "configs/custom_files",
    "commands": [
      "echo 'Build finished' > /var/log/build_status.txt"
    ],
    "files": [
      {
        "src": "configs/custom_files/etc/skel/Desktop/install.desktop",
        "dest": "/etc/skel/Desktop/install.desktop",
        "mode": "0755"
      },
      {
        "src": "configs/custom_files/etc/sudoers.d/99-live-user",
        "dest": "/etc/sudoers.d/99-live-user",
        "mode": "0440"
      }
    ]
  }
}